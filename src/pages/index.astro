---
import Base from "@/layouts/Base.astro";
import { getSanitySettings, getSanityWorks } from "@/lib/sanity";
import { getCollection } from "astro:content";

const settings = await getSanitySettings();
const sanityWorks = await getSanityWorks();
const localWorks = (await getCollection("works")).map((work) => ({
  slug: work.id,
  ...work.data,
}));
const works = (sanityWorks.length > 0 ? sanityWorks : localWorks).filter(
  (work) => work.featured,
);

const siteTitle = settings?.title || "buweihao";
const siteDescription =
  settings?.description || "buweihao 的个人作品集，展示视觉、软件和硬件方向的项目。";
const heroTitle =
  settings?.heroTitle || "buweihao 的视觉、软件与硬件作品集";
const heroDescription =
  settings?.heroDescription ||
  "我关注从概念到落地的完整过程：视觉表达、软件体验和硬件交互如何共同服务一个清晰的想法。";
---

<Base title={siteTitle} description={siteDescription}>
  <section class="section-sm overflow-hidden">
    <div class="container">
      <div class="grid items-center gap-10 lg:grid-cols-[1.05fr_0.95fr]">
        <div>
          <p class="mb-5 text-sm font-medium uppercase text-primary">Personal Portfolio</p>
          <h1 class="mb-6">{heroTitle}</h1>
          <p class="mb-8 max-w-2xl text-lg leading-8 text-text-light dark:text-darkmode-text-light">
            {heroDescription}
          </p>
          <div class="flex flex-wrap gap-4">
            <a class="btn btn-primary" href="/works">查看作品</a>
            <a class="btn btn-outline-primary" href="/contact">联系合作</a>
          </div>
        </div>
        <div>
          <img
            src="/images/banner.png"
            alt="buweihao portfolio"
            class="aspect-[4/3] w-full rounded-md object-cover shadow-xl"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="container">
      <div class="mb-10 flex flex-col justify-between gap-4 md:flex-row md:items-end">
        <div>
          <p class="mb-3 text-sm font-medium uppercase text-primary">Selected Work</p>
          <h2>精选作品</h2>
        </div>
        <a class="text-primary" href="/works">全部作品</a>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {
          works.map((work) => (
            <a
              href={`/works/${work.slug}`}
              class="group overflow-hidden rounded-md border border-border bg-white dark:border-darkmode-border dark:bg-darkmode-light"
            >
              <img src={work.cover} alt={work.title} class="h-48 w-full object-cover" />
              <div class="p-6">
                <p class="mb-3 text-sm text-primary">{work.category}</p>
                <h3 class="h4 mb-3 group-hover:text-primary">{work.title}</h3>
                <p class="leading-7 text-text-light dark:text-darkmode-text-light">
                  {work.description}
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Base>
