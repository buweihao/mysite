---
import Base from "@/layouts/Base.astro";
import { getSanityWorks } from "@/lib/sanity";
import { getCollection } from "astro:content";

const selectedCategory = Astro.url.searchParams.get("category");
const sanityWorks = await getSanityWorks();
const localWorks = (await getCollection("works")).map((work) => ({
  slug: work.id,
  ...work.data,
}));
const allWorks = (sanityWorks.length > 0 ? sanityWorks : localWorks).sort(
  (a, b) => b.year - a.year,
);
const works = selectedCategory
  ? allWorks.filter((work) => work.category === selectedCategory)
  : allWorks;
const categories = ["全部", "视觉", "软件", "硬件"];
---

<Base title="作品" description="buweihao 的视觉、软件和硬件作品集。">
  <section class="section-sm">
    <div class="container">
      <div class="max-w-3xl">
        <p class="mb-4 text-sm font-medium uppercase text-primary">Portfolio</p>
        <h1 class="mb-6">作品</h1>
        <p class="text-lg leading-8 text-text-light dark:text-darkmode-text-light">
          这里整理视觉、软件和硬件三个方向的项目。每个作品都保留从问题、形式到实现的思考痕迹。
        </p>
      </div>

      <div class="mt-10 flex flex-wrap gap-3">
        {
          categories.map((category) => (
            <a
              class:list={[
                "rounded-md border border-border px-4 py-2 text-sm dark:border-darkmode-border",
                (category === "全部" && !selectedCategory) || selectedCategory === category
                  ? "bg-primary text-white"
                  : "",
              ]}
              href={category === "全部" ? "/works" : `/works?category=${encodeURIComponent(category)}`}
            >
              {category}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="container">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          works.map((work) => (
            <a
              href={`/works/${work.slug}`}
              class="group overflow-hidden rounded-md border border-border bg-white transition hover:-translate-y-1 hover:shadow-lg dark:border-darkmode-border dark:bg-darkmode-light"
            >
              <img
                src={work.cover}
                alt={work.title}
                class="h-56 w-full object-cover"
                loading="lazy"
              />
              <div class="p-6">
                <div class="mb-4 flex items-center justify-between text-sm text-text-light dark:text-darkmode-text-light">
                  <span>{work.category}</span>
                  <span>{work.year}</span>
                </div>
                <h2 class="h4 mb-3 group-hover:text-primary">{work.title}</h2>
                <p class="leading-7 text-text-light dark:text-darkmode-text-light">
                  {work.description}
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Base>
