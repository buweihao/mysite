---
import Base from "@/layouts/Base.astro";
import { getSanityWork, getSanityWorks } from "@/lib/sanity";
import { toHTML } from "@portabletext/to-html";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const localWorks = await getCollection("works");
  const sanityWorks = await getSanityWorks();

  const localPaths = localWorks.map((work) => ({
    params: { slug: work.id },
    props: { source: "local", localWork: work },
  }));

  const sanityPaths = sanityWorks.map((work) => ({
    params: { slug: work.slug },
    props: { source: "sanity", sanityWork: work },
  }));

  const sanitySlugs = new Set(sanityWorks.map((work) => work.slug));
  return [
    ...sanityPaths,
    ...localPaths.filter((path) => !sanitySlugs.has(path.params.slug)),
  ];
}

const { source, localWork, sanityWork } = Astro.props;
const currentSanityWork =
  source === "sanity" ? sanityWork : await getSanityWork(Astro.params.slug as string);
const work = currentSanityWork
  ? currentSanityWork
  : {
      slug: localWork.id,
      ...localWork.data,
      body: null,
    };
const localRender = !currentSanityWork && localWork ? await render(localWork) : null;
const sanityBodyHtml = currentSanityWork?.body ? toHTML(currentSanityWork.body as any) : "";
---

<Base title={work.title} description={work.description} image={work.cover}>
  <article class="section-sm">
    <div class="container">
      <a class="mb-8 inline-block text-primary" href="/works">返回作品</a>
      <div class="grid gap-10 lg:grid-cols-[1fr_420px] lg:items-start">
        <div>
          <p class="mb-4 text-sm font-medium uppercase text-primary">{work.category}</p>
          <h1 class="mb-6">{work.title}</h1>
          <p class="text-lg leading-8 text-text-light dark:text-darkmode-text-light">
            {work.description}
          </p>
        </div>
        <div class="rounded-md border border-border p-6 dark:border-darkmode-border">
          <dl class="space-y-4">
            <div class="flex justify-between gap-6">
              <dt class="text-text-light dark:text-darkmode-text-light">年份</dt>
              <dd>{work.year}</dd>
            </div>
            <div class="flex justify-between gap-6">
              <dt class="text-text-light dark:text-darkmode-text-light">分类</dt>
              <dd>{work.category}</dd>
            </div>
            <div>
              <dt class="mb-3 text-text-light dark:text-darkmode-text-light">标签</dt>
              <dd class="flex flex-wrap gap-2">
                {
                  work.tags.map((tag: string) => (
                    <span class="rounded-md bg-light px-3 py-1 text-sm dark:bg-darkmode-body">
                      {tag}
                    </span>
                  ))
                }
              </dd>
            </div>
          </dl>
        </div>
      </div>

      <img
        src={work.cover}
        alt={work.title}
        class="mt-12 aspect-[16/9] w-full rounded-md object-cover"
      />

      <div class="prose mt-12 max-w-3xl dark:prose-invert">
        {
          currentSanityWork ? (
            <Fragment set:html={sanityBodyHtml} />
          ) : (
            localRender && <localRender.Content />
          )
        }
      </div>
    </div>
  </article>
</Base>
