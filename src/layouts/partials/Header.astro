---
import Logo from "@/components/Logo.astro";
import menu from "@/config/menu.json";
import config from "@/config/config.json";
import ThemeSwitcher from "@/components/ThemeSwitcher.astro";

const { navigation_button, settings } = config;

const isMenuItemActive = (url: string) => {
  const pathname = Astro.url.pathname;
  if (url === "/") {
    return pathname === url ? "active" : "";
  }
  return pathname.startsWith(url) ? "active" : "";
};
---

<header
  class:list={[
    "header z-30",
    settings.sticky_header && "sticky top-0",
    "transition-shadow duration-300",
  ]}
>
  <nav class="navbar container">
    <div class="flex items-center">
      <Logo />
    </div>

    <ul class="hidden items-center gap-8 lg:flex">
      {
        menu.main.map((menuItem) => (
          <li>
            <a
              href={menuItem.url}
              class:list={[
                "nav-link transition-colors",
                isMenuItemActive(menuItem.url) && "text-primary font-medium",
              ]}
            >
              {menuItem.name}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="ml-auto flex items-center gap-4">
      <ThemeSwitcher />
      {
        navigation_button.enable && (
          <a class="btn btn-sm btn-primary hidden md:inline-flex" href={navigation_button.link}>
            {navigation_button.label}
          </a>
        )
      }

      <button
        id="nav-toggle-mobile"
        class="rounded-md border border-border p-2 text-text-dark dark:border-border/40 dark:text-white lg:hidden"
        aria-label="打开导航"
      >
        <svg class="h-5 fill-current menu-open" viewBox="0 0 20 20">
          <title>Menu Open</title>
          <path d="M0 3h20v2H0V3z m0 6h20v2H0V9z m0 6h20v2H0V0z"></path>
        </svg>
        <svg class="hidden h-5 fill-current menu-close" viewBox="0 0 20 20">
          <title>Menu Close</title>
          <polygon
            points="11 9 22 9 22 11 11 11 11 22 9 22 9 11 -2 11 -2 9 9 9 9 -2 11 -2"
            transform="rotate(45 10 10)"></polygon>
        </svg>
      </button>
    </div>
  </nav>

  <div class="mobile-menu hidden border-t border-border bg-white dark:border-darkmode-border dark:bg-darkmode-body lg:hidden">
    <div class="container py-4">
      <ul class="space-y-2">
        {
          menu.main.map((menuItem) => (
            <li>
              <a
                href={menuItem.url}
                class:list={[
                  "block rounded-md px-3 py-2",
                  isMenuItemActive(menuItem.url) && "bg-light text-primary dark:bg-darkmode-light",
                ]}
              >
                {menuItem.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</header>

<script>
  function initializePortfolioHeader() {
    const header = document.querySelector("header");
    const toggle = document.querySelector("#nav-toggle-mobile");
    const menu = document.querySelector(".mobile-menu");
    const openIcon = document.querySelector(".menu-open");
    const closeIcon = document.querySelector(".menu-close");

    function updateNavbarShadow() {
      if (window.scrollY > 0) {
        header?.classList.add("shadow-sm");
      } else {
        header?.classList.remove("shadow-sm");
      }
    }

    function toggleMenu() {
      menu?.classList.toggle("hidden");
      openIcon?.classList.toggle("hidden");
      closeIcon?.classList.toggle("hidden");
    }

    window.addEventListener("scroll", updateNavbarShadow);
    toggle?.addEventListener("click", toggleMenu);

    return () => {
      window.removeEventListener("scroll", updateNavbarShadow);
      toggle?.removeEventListener("click", toggleMenu);
    };
  }

  document.addEventListener("astro:page-load", initializePortfolioHeader);
</script>
